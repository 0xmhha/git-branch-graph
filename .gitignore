# deps
node_modules/
# build
.next/
web/dist/
bin/
# embedded SPA build output (staged by `make web`); keep the placeholder.
# Note: use a file glob (not a bare `dist/`) so the negation below can re-include
# .gitkeep — an excluded *directory* cannot have its children re-included.
internal/webui/dist/*
!internal/webui/dist/.gitkeep
# data (생성물: bare mirror 캐시 + 실행별 산출 폴더)
data/.repos/
data/*/
# 단, data 폴더 구조는 유지
!data/.gitkeep
# env / secrets
.env
.env.local
# os
.DS_Store
# sqlite 임시
*.sqlite-journal
*.sqlite-wal
